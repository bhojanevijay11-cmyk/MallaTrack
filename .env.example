# Copy to `.env` for local development (see README or Prisma docs).
#
# SQLite: relative paths in DATABASE_URL are resolved from the project root
# (directory that contains the `prisma/` folder). Example: `file:./dev.db`
# → <repo>/dev.db
#
# Schema changes: use migrations only (do not use `prisma db push` in shared/prod workflows).
#   Local:  npm run migrate:dev
#   CI/prod after deploy:  npm run migrate:deploy
# If you already have a DB created before migrations existed, baseline it once:
#   npx prisma migrate resolve --applied 20260405174625_baseline
DATABASE_URL="file:./dev.db"

# ------------------------------------------------------------
# Postgres (production example)
# ------------------------------------------------------------
# For production, point DATABASE_URL at Postgres and use the :pg Prisma scripts:
#   npm run generate:pg
#   npm run migrate:deploy:pg
#   npm run migrate:status:pg
#
# Example (adjust user/pass/host/db and SSL params for your provider):
# DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DBNAME?schema=public"

# Match `npm run dev` (package.json pins port 3002).
NEXTAUTH_URL=http://localhost:3002
NEXTAUTH_SECRET=
