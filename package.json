{
  "name": "mallatrack",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack --port 3002",
    "dev:webpack": "next dev --port 3002",
    "dev:clean": "rm -rf .next && next dev --turbopack --port 3002",
    "build:clean": "rm -rf .next && node scripts/prisma-generate-for-db-url.js && next build",
    "build": "node scripts/prisma-generate-for-db-url.js && next build",
    "build:pg": "node scripts/prisma-generate-for-db-url.js --pg && next build",
    "start": "next start",
    "lint": "next lint",
    "postinstall": "prisma generate",
    "postinstall:pg": "node scripts/prisma-generate-for-db-url.js --pg",
    "migrate:dev": "prisma migrate dev",
    "migrate:deploy": "prisma migrate deploy",
    "migrate:status": "prisma migrate status",
    "generate:pg": "node scripts/prisma-generate-for-db-url.js --pg",
    "migrate:dev:pg": "prisma migrate dev --schema prisma/pg/schema.prisma",
    "migrate:deploy:pg": "prisma migrate deploy --schema prisma/pg/schema.prisma",
    "migrate:status:pg": "prisma migrate status --schema prisma/pg/schema.prisma",
    "migrate:resolve-baseline": "prisma migrate resolve --applied 20260405174625_baseline",
    "migrate:resolve-baseline:pg": "prisma migrate resolve --schema prisma/pg/schema.prisma --applied 20260428125700_baseline",
    "db:push:pg": "prisma db push --schema prisma/pg/schema.prisma",
    "seed:admin": "node scripts/seed-admin.js",
    "cleanup:user": "node scripts/cleanup-user.js",
    "backfill:legacy-batch-branches": "node scripts/backfill-legacy-batch-branches.js",
    "backfill:institute": "tsx scripts/backfill-institute.ts",
    "seed:two-institutes:dev": "tsx scripts/seed-two-institutes-dev.ts",
    "seed:super-admin:dev": "node scripts/seed-super-admin-dev.js"
  },
  "dependencies": {
    "@prisma/client": "^6.19.0",
    "bcryptjs": "^3.0.2",
    "dotenv": "^17.3.1",
    "lucide-react": "^0.468.0",
    "next": "^15.1.0",
    "next-auth": "^4.24.13",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22.10.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "prisma": "^6.19.0",
    "tailwindcss": "^3.4.16",
    "tsx": "^4.21.0",
    "typescript": "^5.7.0"
  }
}
